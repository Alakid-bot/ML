# Example environment variables for local development and Zeabur deployment.
# Copy this file to .env and adjust values. No secrets should be committed.

# SQLite is used when this variable is empty or unset.
# For Zeabur, set this to the provisioned PostgreSQL URI, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=

# Root directory for uploaded CSVs, joblib models, and metrics JSON.
# Local default: artifacts/streamlit_runs
# Zeabur durable disk mount: /data/training_runs
ARTIFACT_ROOT=artifacts/streamlit_runs
